# Core bot identity
BOT_NAME=Chathu MD
OWNER_NUMBER=94742514900
PREFIX=.

# Runtime ports
PORT=5000
DASHBOARD_PORT=5000

# Dashboard auth (change these in production)
ADMIN_USER=admin
ADMIN_PASS=change-this-password
